{
  "name": "splat-transform-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "Workspace for 3D Gaussian splat format conversion and transformation tools",
  "license": "MIT",
  "devDependencies": {
    "@playcanvas/eslint-config": "2.1.0",
    "@playcanvas/supersplat-viewer": "1.9.0",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/jsdom": "27.0.0",
    "@types/node": "24.10.1",
    "@typescript-eslint/eslint-plugin": "8.48.0",
    "@typescript-eslint/parser": "8.48.0",
    "eslint": "9.39.1",
    "eslint-import-resolver-typescript": "4.4.4",
    "playcanvas": "2.13.6",
    "publint": "0.3.15",
    "rollup": "4.53.3",
    "tslib": "2.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "npm run build -w @playcanvas/splat-transform-api && npm run build -w @playcanvas/splat-transform",
    "lint": "eslint packages/*/src packages/*/rollup.config.mjs eslint.config.mjs",
    "lint:fix": "eslint packages/*/src packages/*/rollup.config.mjs eslint.config.mjs --fix",
    "publint": "npm run publint --workspaces --if-present",
    "watch": "npm run watch --workspaces"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module"
}
